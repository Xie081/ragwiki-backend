# Environment variables for local development
# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# DeepSeek API Key (required for AI chat — get one at https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# SiliconFlow API Key (required for embedding vectors — get one at https://siliconflow.cn)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# JWT Secret (use a long random string, at least 256 bits)
JWT_SECRET=generate-a-random-secret-key-at-least-256-bits

# PostgreSQL connection (defaults shown below; uncomment to override)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/rag_wiki
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
